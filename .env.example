# Base de datos
DATABASE_URL=postgresql://belleza_user:belleza_pass@localhost:5432/belleza_db

# JWT
JWT_SECRET_KEY=cambia-esto-por-un-string-largo-y-aleatorio
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# AWS S3 (en local apunta a MinIO)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
S3_BUCKET_NAME=belleza-assets
S3_ENDPOINT_URL=http://localhost:9000

# Email (en local usa Mailtrap)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=tu-usuario-mailtrap
SMTP_PASSWORD=tu-password-mailtrap
EMAILS_FROM=noreply@bellezagdl.com

# Odoo (en local usa mock)
ODOO_URL=http://localhost:8069
ODOO_DB=odoo
ODOO_USER=admin
ODOO_PASSWORD=admin

# Ambiente
ENVIRONMENT=local
